{
  "name": "cnpj-open-data-api",
  "version": "1.0.0",
  "description": "API NestJS para leitura dos dados de CNPJ em MongoDB",
  "private": true,
  "license": "ISC",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
